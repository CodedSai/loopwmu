-- CFUNC
local function parseCFrame(input)
    local numbers = {}
    for num in input:gmatch("-?%d+%.?%d*") do
        table.insert(numbers, tonumber(num))
    end
    if #numbers == 12 then
        return CFrame.new(
            numbers[1], numbers[2], numbers[3],
            numbers[4], numbers[5], numbers[6],
            numbers[7], numbers[8], numbers[9],
            numbers[10], numbers[11], numbers[12]
        )
    elseif #numbers == 3 then
        return CFrame.new(numbers[1], numbers[2], numbers[3])
    end
    return nil
end

local function teleportToCFrame(input)
    local cf = parseCFrame(input)
    if not cf then return false end
    local character = player.Character
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = cf
    return true
end

local function parseToVector(text)
    local numbers = {}
    for num in string.gmatch(text, "[-+.%d]+") do
        table.insert(numbers, tonumber(num))
    end
    if #numbers >= 3 then
        return Vector3.new(numbers[1], numbers[2], numbers[3])
    end
    return nil
end

local function placeSprinkler(targetPositionString)
    local character = player.Character
    local human = character and character:FindFirstChildOfClass("Humanoid")
    local backpack = player:FindFirstChildOfClass("Backpack")
    local item = backpack and backpack:FindFirstChild("Super Sprinkler")
    
    local targetVector = parseToVector(targetPositionString)
    if not targetVector then return false end
    
    if item and human then
        human:EquipTool(item)
        local toolInCharacter = character:WaitForChild("Super Sprinkler", 3)
        if toolInCharacter then
            task.wait(0.1)
            local args = {
                20,
                targetVector,
                "Super Sprinkler",
                toolInCharacter,
                1
            }
            pcall(function()
                PacketRemote:FireServer(unpack(args))
            end)
            task.wait(0.3)
            human:UnequipTools()
            return true
        end
    end
    return false
end

