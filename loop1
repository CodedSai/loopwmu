local function executeStartLogic()
    started = not started
    if started then
        StartBtn.Text = "Stop"
        StartBtn.TextColor3 = Color3.fromRGB(239, 83, 80)
        StartBtn.BackgroundColor3 = Color3.fromRGB(28, 19, 21)
        startBtnStroke.Color = Color3.fromRGB(239, 83, 80)
        
        if toggles["Auto Tp"].getState() then
            task.spawn(function()
                while started and toggles["Auto Tp"].getState() do
                    teleportToCFrame(TeleportInput.Text)
                    task.wait(0.5)
                end
            end)
        end

        if toggles["Auto Rejoin"].getState() then
            task.spawn(function()
                local countdown = 3
                while started and toggles["Auto Rejoin"].getState() do
                    local waterCan = player.Backpack:FindFirstChild("Super Watering Can") or player.Character:FindFirstChild("Super Watering Can")
                    
                    if not waterCan then
                        countdown = countdown - 1
                        if countdown <= 0 then
                            started = false
                            pcall(function() 
                                game:GetService("TeleportService"):Teleport(game.PlaceId, player) 
                            end)
                            break
                        end
                    else
                        countdown = 5
                    end
                    task.wait(1)
                end
            end)
        end

        if toggles["Auto Sprinkler"].getState() then
            task.spawn(function()
                while started and toggles["Auto Sprinkler"].getState() do
                    teleportToCFrame(SprinklerInput.Text)
                    task.wait(2)
                    placeSprinkler(SprinklerInput.Text)
                    task.wait(122)
                end
            end)
        end

        if toggles["Auto Water"].getState() then
            task.spawn(function()
                while started and toggles["Auto Water"].getState() do
                    useSuperWateringCan()
                    task.wait(5)
                end
            end)
        end

    else
        StartBtn.Text = "Start"
        StartBtn.TextColor3 = Color3.fromRGB(179, 136, 255)
        StartBtn.BackgroundColor3 = Color3.fromRGB(24, 20, 34)
        startBtnStroke.Color = Color3.fromRGB(179, 136, 255)
    end
end

