local function buildToggle(labelText, col, row)
    local colX = (col == 0) and 0 or 163
    local rowY = 288 + row * 40

    local Item = newFrame({
        Name = labelText .. "Item",
        Position = UDim2.fromOffset(colX, rowY),
        Size = UDim2.fromOffset(139, 36),
    }, Content)

    newLabel({
        Name = "Label",
        Position = UDim2.fromOffset(0, 0),
        Size = UDim2.fromOffset(90, 36),
        Text = labelText,
        TextColor3 = Color3.fromRGB(179, 169, 194),
        TextSize = 13,
        Font = Enum.Font.Gotham,
    }, Item)

    local state = false
    if SavedSettings and type(SavedSettings) == "table" and SavedSettings.Toggles and SavedSettings.Toggles[labelText] ~= nil then
        state = SavedSettings.Toggles[labelText]
    end

    local Btn = newButton({
        Name = "Toggle",
        Position = UDim2.new(1, -40, 0, 0),
        Size = UDim2.fromOffset(40, 36),
        Text = state and "ON" or "OFF",
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        BackgroundTransparency = 1,
        TextColor3 = state and Color3.fromRGB(0, 230, 118) or Color3.fromRGB(239, 83, 80),
    }, Item)

    Btn.MouseButton1Click:Connect(function()
        state = not state
        
        if labelText == "Auto Vuln" then
            if state then
                pcall(function() PacketRemote:FireServer(buffer.fromstring("6\x00\x01\xff")) end)
            else
                pcall(function() PacketRemote:FireServer(buffer.fromstring("6\x00\x00")) end)
            end
        elseif labelText == "Fps Booster" then
            if state then
                task.spawn(function()
                    local Lighting = game:GetService("Lighting")
                    local Workspace = game:GetService("Workspace")

                    Lighting.GlobalShadows = false
                    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

                    local targetFolder = Workspace:FindFirstChild("Gardens")
                        and Workspace.Gardens:FindFirstChild("Plot1")
                        and Workspace.Gardens.Plot1:FindFirstChild("Plants")

                    local function cleanPart(obj)
                        if obj:IsA("BasePart") then
                            obj.CastShadow = false
                            obj.Material = Enum.Material.SmoothPlastic
                            obj.Reflectance = 0
                            
                            if targetFolder and obj:IsDescendantOf(targetFolder) then
                                local isFruit = false
                                local ancestor = obj.Parent
                                
                                while ancestor and ancestor ~= targetFolder do
                                    if ancestor.Name == "Fruits" then
                                        isFruit = true
                                        break
                                    end
                                    ancestor = ancestor.Parent
                                end
                                
                                if not isFruit then
                                    obj.Transparency = 1
                                    obj.CanCollide = false
                                end
                            end
                        elseif obj:IsA("Decal") or obj:IsA("Texture") then
                            obj:Destroy()
                        end
                    end

                    for _, v in ipairs(Workspace:GetDescendants()) do
                        cleanPart(v)
                    end

                    Workspace.DescendantAdded:Connect(cleanPart)
                end)
            end
        end

        if state then
            Btn.Text = "ON"
            Btn.TextColor3 = Color3.fromRGB(0, 230, 118)
        else
            Btn.Text = "OFF"
            Btn.TextColor3 = Color3.fromRGB(239, 83, 80)
        end
    end)

    toggles[labelText] = { button = Btn, getState = function() return state end }
    return Btn
end

